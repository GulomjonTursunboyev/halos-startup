# Telegram Bot Token from @BotFather
BOT_TOKEN=your_bot_token_here

# Database path (optional, defaults to data/solvo.db)
DATABASE_PATH=data/solvo.db

# Admin user IDs (comma-separated, for future admin features)
ADMIN_IDS=123456789

# Click Payment Integration
CLICK_SERVICE_ID=18870
CLICK_MERCHANT_ID=18870
CLICK_SECRET_KEY=your_click_secret_key

# Webhook Base URL (your Render web service URL)
WEBHOOK_BASE_URL=https://solvo-click.onrender.com
